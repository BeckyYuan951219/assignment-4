<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="apple-card border-0">
      <div class="text-center mb-4">
        <h1 class="fw-bold h2">New Post</h1>
        <p class="text-muted">Adding a memory for <strong class="text-dark"><%= @place["name"] %></strong></p>
      </div>

      <form action="/entries" method="post" enctype="multipart/form-data">
        <input type="hidden" name="place_id" value="<%= @place["id"] %>">

        <div class="mb-3">
          <label for="title_input" class="form-label">Title</label>
          <input type="text" name="title" id="title_input" class="form-control" placeholder="A memorable title" required>
        </div>

        <div class="mb-3">
          <label for="date_input" class="form-label">Date</label>
          <input type="date" name="occurred_on" id="date_input" class="form-control" required>
        </div>

        <div class="mb-3">
          <label for="file_input" class="form-label">Upload Image</label>
          <input type="file" name="uploaded_image" id="file_input" class="form-control">
        </div>

        <div class="mb-3 text-center">
          <span class="text-muted small">OR</span>
        </div>

        <div class="mb-4">
          <label for="image_input" class="form-label">Image URL (Optional)</label>
          <input type="text" name="image_url" id="image_input" class="form-control" placeholder="https://...">
        </div>

        <div class="mb-4">
          <label for="description_input" class="form-label">Description</label>
          <textarea name="description" id="description_input" class="form-control" rows="5" placeholder="Write about your experience..."></textarea>
        </div>

        <div class="d-flex justify-content-end gap-2">
          <a href="/places/<%= @place["id"] %>" class="btn btn-secondary">Cancel</a>
          <button class="btn btn-primary px-4">Save Post</button>
        </div>
      </form>
    </div>
  </div>
</div>