<div class="row justify-content-between align-items-center mb-5">
  <div class="col-auto">
    <h1 class="page-title mb-0">Places</h1>
  </div>
  <div class="col-auto">
    <% if session["user_id"] != nil %>
      <a href="/places/new" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Place
      </a>
    <% end %>
  </div>
</div>

<div class="row">
  <div class="col-md-8 mx-auto">
    <div class="list-group shadow-sm">
      <% for place in @places %>
        <a href="/places/<%= place["id"] %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
          <span class="fw-medium"><%= place["name"] %></span>
          <i class="bi bi-chevron-right text-muted"></i>
        </a>
      <% end %>
    </div>
  </div>
</div>